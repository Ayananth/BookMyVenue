DATABASE_URL=postgresql+asyncpg://bookmyvenue:bookmyvenue@postgres:5432/bookmyvenue
# Must match Django backend SECRET_KEY so login tokens validate here.
SECRET_KEY=change-me-to-match-backend
JWT_ALGORITHM=HS256

# Backend internal API — must match backend INTERNAL_API_KEY
BACKEND_BASE_URL=http://backend:8000
INTERNAL_API_KEY=change-me-to-a-long-random-secret
BACKEND_HTTP_TIMEOUT=5.0

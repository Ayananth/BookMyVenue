# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Asia/Kolkata

# Database
DATABASE_URL=postgres://bookmyvenue:bookmyvenue@postgres:5432/bookmyvenue

# Redis (cache + Celery broker)
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email
# Dev: use console backend to print OTP in logs (no real email)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Prod/local real email:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-no-spaces
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=BookMyVenue <your-email@gmail.com>
APP_NAME=BookMyVenue
APP_SUPPORT_EMAIL=support@example.com
CONTACT_NOTIFICATION_EMAIL=admin@example.com

# OTP (stored in Redis)
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Cloudinary (recommended for production image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Payment gateways (optional)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS / CSRF (comma-separated; include every frontend origin that calls the API)
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
# Production example:
# CORS_ALLOWED_ORIGINS=https://bookmyvenue.ayananth.xyz
# CSRF_TRUSTED_ORIGINS=https://bookmyvenue.ayananth.xyz

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
